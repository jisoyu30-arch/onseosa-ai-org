    "Eden Plan": { "main": [[{ "node": "Ria Write", "type": "main", "index": 0 }]] },
    "Ria Write": { "main": [[{ "node": "Kal Review", "type": "main", "index": 0 }]] },
    "Kal Review": { "main": [[{ "node": "Score >= 75?", "type": "main", "index": 0 }]] },
    "Score >= 75?": {
      "main": [
        [{ "node": "Luka Record", "type": "main", "index": 0 }],
        [{ "node": "Ria Retry", "type": "main", "index": 0 }]
      ]
    }
