            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ projectId: 'auto', projectName: $('Set Input').item.json.projectName, projectType: $('Set Input').item.json.projectType, taskType: 'record', instruction: '결과 저장', context: { outputData: $('Ria Write').item.json.output, feedback: $('Kal Review').item.json.output.summary } }) }}"
      },
      "id": "luka-record",
      "name": "Luka Record",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
