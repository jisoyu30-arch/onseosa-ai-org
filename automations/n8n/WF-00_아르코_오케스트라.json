            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ projectId: 'auto', projectName: $('Set Input').item.json.projectName, projectType: $('Set Input').item.json.projectType, taskType: 'write', instruction: $('Set Input').item.json.goal + ' [재시도] 수정사항: ' + ($('Kal Review').item.json.output.data.fix_instruction || '품질 향상 필요'), context: $('Eden Plan').item.json.output }) }}"
      },
      "id": "ria-retry",
      "name": "Ria Retry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 420]
    }
