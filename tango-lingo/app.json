{
  "expo": {
    "name": "TangoLingo",
    "slug": "tango-lingo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "tangolingo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "bundleIdentifier": "com.onseosa.tangolingo",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "발음 평가를 위해 마이크 사용 권한이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "음성을 텍스트로 변환하여 발음을 평가합니다."
      }
    },
    "android": {
      "package": "com.onseosa.tangolingo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "발음 평가를 위해 마이크 권한이 필요합니다.",
          "speechRecognitionPermission": "음성 인식으로 발음을 평가합니다.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "859f7aa7-02e5-4d70-a789-80ed44b03777"
      }
    },
    "owner": "onseosa"
  }
}
