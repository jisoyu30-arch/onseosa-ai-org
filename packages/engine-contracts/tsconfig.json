{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@ons/*": ["../*/src"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../shared-types" }
  ]
}
