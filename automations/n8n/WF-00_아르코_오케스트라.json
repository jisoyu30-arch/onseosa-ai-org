  "connections": {
    "Webhook Trigger": { "main": [[{ "node": "Set Input", "type": "main", "index": 0 }]] },
    "Set Input": { "main": [[{ "node": "Arko Orchestrate", "type": "main", "index": 0 }]] },
    "Arko Orchestrate": { "main": [[{ "node": "Noah Analyze", "type": "main", "index": 0 }]] },
